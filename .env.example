
# 要加载的模型名称
# 可选值：resnet50, mobilenet_v2
# 默认值：resnet50
# resnet50（ResNet-50，为图像分类常用的卷积神经网络）
# mobilenet_v2（MobileNetV2，轻量级的卷积神经网络）
MODEL_NAME=resnet50

# 存储/缓存模型权重的路径
# 默认值：~/.cache/torch/hub (标准 PyTorch 缓存)
# 如需要可以指定自定义路径
MODEL_PATH=/.cache/torch/hub

# 运行推理的设备
# 可选值：cpu, cuda (如果有 GPU), mps (用于 Apple Silicon)
# 默认值：cpu
DEVICE=cpu

# 服务器绑定的主机地址
# 0.0.0.0 = 监听所有网络接口 (用于 Docker)
# 127.0.0.1 = 仅监听本地回环 (用于本地开发)
# 默认值：0.0.0.0
HOST=0.0.0.0

# 监听端口
# 默认值：5000
# 注意：小于 1024 的端口需要 root 权限
PORT=5000

# 启用调试模式
# true = 详细日志，代码变更时自动重载
# false = 生产模式
# 默认值：false
# 警告：永远不要在生产环境启用调试模式！
DEBUG=false

# API 版本
# 遵循语义化版本控制 (MAJOR.MINOR.PATCH)
# 默认值：1.0.0
API_VERSION=1.0.0

# 上传文件的最大大小（字节）
# 默认值：10485760 (10MB)
# 防止通过大文件上传进行 DOS 攻击
MAX_FILE_SIZE=10485760

# 图像的最大尺寸（宽度或高度，像素）
# 默认值：4096
# 防止因超大图像导致的内存问题
MAX_IMAGE_DIMENSION=4096

# 请求超时时间（秒）
# 默认值：30
# 处理单个请求的最大时间
REQUEST_TIMEOUT=30

# 默认返回的预测数量
# 默认值：5
DEFAULT_TOP_K=5

# 允许的最大预测数量
# 默认值：10
# 限制 top_k 参数的最大值
MAX_TOP_K=10

# 日志级别
# 可选值：DEBUG, INFO, WARNING, ERROR, CRITICAL
# 默认值：INFO
# - DEBUG: 非常详细，用于开发
# - INFO: 正常操作消息
# - WARNING: 警告消息（不寻常但可恢复）
# - ERROR: 错误消息（请求失败）
# - CRITICAL: 严重问题（系统故障）
LOG_LEVEL=INFO


# 日志格式
# 可选值：json, text
# 默认值：json
# - json: 结构化日志（更适合日志聚合）
# - text: 人类可读格式（更适合开发）
LOG_FORMAT=json

# 下载 ImageNet 类别标签的 URL
# 默认值：PyTorch Hub GitHub 仓库
# 用于分类的类别，从这里下载
IMAGENET_LABELS_URL=https://raw.githubusercontent.com/pytorch/hub/master/imagenet_classes.txt